<!-- ===================== SCRIPTS ===================== -->
<script>
/* -------------------------------------------------------
   STARFIELD BACKGROUND
------------------------------------------------------- */
(function () {
  const canvas = document.getElementById('starfield');
  const ctx = canvas.getContext('2d');
  let W, H, stars = [];

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }

  function makeStars(n) {
    stars = [];
    for (let i = 0; i < n; i++) {
      stars.push({
        x: Math.random() * W,
        y: Math.random() * H,
        r: Math.random() * 1.5 + 0.3,
        a: Math.random(),
        sp: Math.random() * 0.008 + 0.002,
        d: Math.random() < 0.5 ? 1 : -1
      });
    }
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    for (const s of stars) {
      s.a += s.sp * s.d;
      if (s.a >= 1 || s.a <= 0) s.d *= -1;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(200,160,32,${s.a * 0.7})`;
      ctx.fill();
    }
    requestAnimationFrame(draw);
  }

  window.addEventListener('resize', () => { resize(); makeStars(120); });
  resize();
  makeStars(120);
  draw();
})();


/* -------------------------------------------------------
   TOKEN CONFIG
   ▶ Once $OSRSFANS is deployed on Solana, set TOKEN_MINT_ADDRESS
     to the SPL token mint address. Until then (null) any connected
     wallet can vote — no balance check is performed.
------------------------------------------------------- */
const TOKEN_MINT_ADDRESS = null; // e.g. 'OSRSfANS1111111111111111111111111111111111111'
const MIN_TOKEN_BALANCE  = 1;   // minimum $OSRSFANS a wallet must hold to vote
const SOLANA_RPC         = 'https://api.mainnet-beta.solana.com'; // swap for a paid RPC in production

/* -------------------------------------------------------
   WALLET STATE
------------------------------------------------------- */
let walletAddress = null;
let holdsToken    = false; // true once wallet connected & token balance verified
let currentPeriod = 'weekly';

async function toggleWallet() {
  if (walletAddress) {
    disconnectWallet();
  } else {
    await connectWallet();
  }
}

async function connectWallet() {
  if (!window.solana?.isPhantom) {
    showToast('⚠ Phantom Wallet not found! Install it at phantom.app', true);
    window.open('https://phantom.app', '_blank');
    return;
  }
  try {
    updateGate('checking');
    const resp = await window.solana.connect();
    walletAddress = resp.publicKey.toString();
    updateNavBtn();
    await verifyTokenHolder();
  } catch (e) {
    walletAddress = null;
    updateGate('disconnected');
    showToast('❌ Connection cancelled.', true);
  }
}

function disconnectWallet() {
  walletAddress = null;
  holdsToken    = false;
  if (window.solana?.disconnect) window.solana.disconnect();
  updateNavBtn();
  updateGate('disconnected');
  renderLeaderboard(currentPeriod);
  showToast('🔌 Wallet disconnected.');
}

/* Check SPL token balance. If TOKEN_MINT_ADDRESS is null (not yet
   deployed), skip the check and grant access on wallet connection alone. */
async function verifyTokenHolder() {
  if (!TOKEN_MINT_ADDRESS) {
    // Pre-launch mode: token not deployed yet — wallet connection is enough
    holdsToken = true;
    updateNavBtn();
    updateGate('hidden');
    renderLeaderboard(currentPeriod);
    showToast('✅ Wallet connected: ' + shortenAddr(walletAddress));
    return;
  }

  // Token deployed — check on-chain SPL balance
  updateGate('checking');
  try {
    const connection = new solanaWeb3.Connection(SOLANA_RPC, 'confirmed');
    const owner      = new solanaWeb3.PublicKey(walletAddress);
    const mint       = new solanaWeb3.PublicKey(TOKEN_MINT_ADDRESS);
    const accounts   = await connection.getParsedTokenAccountsByOwner(owner, { mint });
    const balance    = accounts.value.reduce((sum, a) => {
      return sum + (a.account.data.parsed.info.tokenAmount.uiAmount || 0);
    }, 0);
    holdsToken = balance >= MIN_TOKEN_BALANCE;
  } catch (err) {
    console.error('Token balance check failed:', err);
    holdsToken = false;
  }

  updateNavBtn();
  if (holdsToken) {
    updateGate('hidden');
    renderLeaderboard(currentPeriod);
    showToast('✅ Wallet connected: ' + shortenAddr(walletAddress));
  } else {
    updateGate('no_tokens');
    showToast('⚠ No $OSRSFANS found in your wallet!', true);
  }
}

/* Update the nav connect button label */
function updateNavBtn() {
  const btn = document.getElementById('connectBtn');
  if (walletAddress && holdsToken) {
    btn.textContent = '✅ ' + shortenAddr(walletAddress);
    btn.classList.add('connected');
  } else if (walletAddress) {
    btn.textContent = '⚠ ' + shortenAddr(walletAddress);
    btn.classList.remove('connected');
  } else {
    btn.textContent = 'Connect Wallet';
    btn.classList.remove('connected');
  }
}

/* Drive the gate overlay state machine:
     'disconnected' → show connect prompt
     'checking'     → show verifying spinner
     'no_tokens'    → show buy CTA
     'hidden'       → remove gate, reveal voting UI */
function updateGate(state) {
  const gate       = document.getElementById('voteGate');
  const icon       = document.getElementById('gateIcon');
  const title      = document.getElementById('gateTitle');
  const msg        = document.getElementById('gateMsg');
  const connectBtn = document.getElementById('gateConnectBtn');
  const buyBtn     = document.getElementById('gateBuyBtn');
  const statusEl   = document.getElementById('gateStatus');

  if (state === 'hidden') {
    gate.classList.add('hidden');
    return;
  }
  gate.classList.remove('hidden');

  if (state === 'disconnected') {
    icon.textContent    = '🔒';
    title.textContent   = 'WALLET REQUIRED';
    msg.innerHTML       = 'Connect your Phantom wallet to vote.<br/>You must hold <span style="color:var(--gold)">$OSRSFANS</span> to participate.';
    connectBtn.style.display = '';
    buyBtn.style.display     = 'none';
    statusEl.textContent     = '';
    statusEl.className       = 'token-status';
  } else if (state === 'checking') {
    icon.textContent    = '⏳';
    title.textContent   = 'VERIFYING...';
    msg.innerHTML       = 'Checking your <span style="color:var(--gold)">$OSRSFANS</span> balance on Solana...';
    connectBtn.style.display = 'none';
    buyBtn.style.display     = 'none';
    statusEl.textContent     = 'Please wait...';
    statusEl.className       = 'token-status checking';
  } else if (state === 'no_tokens') {
    icon.textContent    = '❌';
    title.textContent   = 'NO $OSRSFANS FOUND';
    msg.innerHTML       = 'Your wallet holds no <span style="color:var(--gold)">$OSRSFANS</span> tokens.<br/>You need at least 1 $OSRSFANS to vote.';
    connectBtn.style.display = 'none';
    buyBtn.style.display     = '';
    statusEl.textContent     = '0 $OSRSFANS in wallet';
    statusEl.className       = 'token-status fail';
  }
}

function shortenAddr(a) {
  return a.slice(0, 4) + '…' + a.slice(-4);
}

// Auto-reconnect on page load if Phantom already approved this site
window.addEventListener('load', async () => {
  updateGate('disconnected');
  if (window.solana?.isPhantom) {
    try {
      const resp = await window.solana.connect({ onlyIfTrusted: true });
      walletAddress = resp.publicKey.toString();
      updateNavBtn();
      await verifyTokenHolder();
    } catch (_) { /* not previously approved — stay disconnected */ }
  }
  renderLeaderboard('weekly');
  updateCountdown('weekly');
});


/* -------------------------------------------------------
   VOTING DATA & LOGIC
------------------------------------------------------- */
const DEFAULT_STREAMERS = {
  weekly:  buildStreamers(),
  monthly: buildStreamers(),
  yearly:  buildStreamers()
};

function buildStreamers() {
  return [
    { name: 'B0aty',         platform: 'Twitch', base: 4200 },
    { name: 'Torvesta',      platform: 'YouTube + Twitch', base: 3100 },
    { name: 'Settled',       platform: 'YouTube', base: 2800 },
    { name: 'Woox',          platform: 'Twitch', base: 1950 },
    { name: 'SirPugger',     platform: 'Twitch', base: 1600 },
    { name: 'A Friend',      platform: 'Twitch', base: 1450 },
    { name: 'Framed',        platform: 'YouTube', base: 1100 },
    { name: 'J1mmy',         platform: 'Twitch', base: 850  },
    { name: 'Tanzoo',        platform: 'YouTube + Twitch', base: 720 },
    { name: 'Virtoso',       platform: 'YouTube + Twitch', base: 680 },
  ];
}

function getVoteKey(period, streamer) {
  return `osrsfans_votes_${period}_${streamer.replace(/\s+/g,'_')}`;
}
function getVotedKey(period) {
  return `osrsfans_voted_${period}_${walletAddress || 'anon'}`;
}

function getVotes(period, streamer) {
  const stored = localStorage.getItem(getVoteKey(period, streamer));
  if (stored !== null) return parseInt(stored);
  // Default seeded values
  const found = DEFAULT_STREAMERS[period].find(s => s.name === streamer);
  return found ? found.base : 0;
}

function getStreamers(period) {
  const def = DEFAULT_STREAMERS[period].map(s => s.name);
  const extra = JSON.parse(localStorage.getItem(`osrsfans_extra_${period}`) || '[]');
  return [...def, ...extra.filter(n => !def.includes(n))];
}

function addExtraStreamer(period, name) {
  const key = `osrsfans_extra_${period}`;
  const existing = JSON.parse(localStorage.getItem(key) || '[]');
  if (!existing.includes(name)) {
    existing.push(name);
    localStorage.setItem(key, JSON.stringify(existing));
  }
}

function castVote(period, streamer) {
  if (!walletAddress || !holdsToken) {
    showToast('⚠ Connect your Phantom wallet first!', true);
    return;
  }
  const votedKey = getVotedKey(period);
  if (localStorage.getItem(votedKey)) {
    showToast('⚠ You already voted this ' + period + '!', true);
    return;
  }
  const voteKey = getVoteKey(period, streamer);
  const cur = getVotes(period, streamer);
  localStorage.setItem(voteKey, cur + 1);
  localStorage.setItem(votedKey, streamer);
  showToast('🗳 Vote cast for ' + streamer + '! GG!');
  renderLeaderboard(period);
}

function nominate() {
  const input = document.getElementById('nominateInput');
  const name = input.value.trim();
  if (!name) return;
  if (!walletAddress || !holdsToken) { showToast('⚠ Connect wallet to nominate!', true); return; }

  const streamers = getStreamers(currentPeriod);
  if (streamers.map(s => s.toLowerCase()).includes(name.toLowerCase())) {
    showToast('⚠ ' + name + ' is already on the list!', true);
    input.value = '';
    return;
  }
  if (name.length < 2) { showToast('⚠ Name too short!', true); return; }

  addExtraStreamer(currentPeriod, name);
  // Give it a seed vote of 0
  localStorage.setItem(getVoteKey(currentPeriod, name), 0);
  input.value = '';
  renderLeaderboard(currentPeriod);
  showToast('✅ ' + name + ' has been nominated!');
}


/* -------------------------------------------------------
   RENDER LEADERBOARD
------------------------------------------------------- */
function renderLeaderboard(period) {
  const el = document.getElementById('leaderboard');
  const streamers = getStreamers(period);

  const data = streamers.map(name => ({
    name,
    platform: (DEFAULT_STREAMERS[period].find(s => s.name === name) || {}).platform || 'Twitch / YouTube',
    votes: getVotes(period, name)
  }));

  data.sort((a, b) => b.votes - a.votes);
  const max = data[0]?.votes || 1;

  const votedFor = walletAddress ? localStorage.getItem(getVotedKey(period)) : null;

  el.innerHTML = data.map((s, i) => {
    const rank = i + 1;
    const rankClass = rank <= 3 ? `rank-${rank}` : '';
    const rankLabel = rank === 1 ? '👑' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : rank;
    const rankBadgeClass = rank > 3 ? 'default' : '';
    const pct = Math.round((s.votes / max) * 100);

    const alreadyVoted = votedFor !== null;
    const votedThis = votedFor === s.name;
    // Gate overlay handles locked state — buttons here only need voted/unvoted states
    let btnClass = 'btn btn-sm';
    let btnLabel = '▶ Vote';
    let btnDisabled = '';
    if (votedThis)     { btnClass = 'btn btn-sm btn-voted'; btnLabel = '✅ Voted!'; btnDisabled = 'disabled'; }
    else if (alreadyVoted) { btnClass = 'btn btn-sm btn-voted'; btnLabel = '🔒 Voted'; btnDisabled = 'disabled'; }

    const fmtVotes = s.votes.toLocaleString();

    return `
      <div class="streamer-row ${rankClass}">
        <div class="rank-badge ${rankBadgeClass}">${rankLabel}</div>
        <div class="streamer-info">
          <div class="streamer-name">${s.name}</div>
          <div class="streamer-platform">${s.platform}</div>
        </div>
        <div class="vote-bar-wrap">
          <div class="vote-bar-bg"><div class="vote-bar-fill" style="width:${pct}%"></div></div>
          <div class="vote-count">${fmtVotes} votes</div>
        </div>
        <button class="${btnClass}" ${btnDisabled} onclick="castVote('${period}','${s.name}')">${btnLabel}</button>
      </div>
    `;
  }).join('');
}


/* -------------------------------------------------------
   TABS
------------------------------------------------------- */
function setTab(period, btn) {
  currentPeriod = period;
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');

  const titles = { weekly: '🏅 WEEKLY LEADERBOARD', monthly: '📆 MONTHLY LEADERBOARD', yearly: '🏆 YEARLY LEADERBOARD' };
  document.getElementById('voteTitle').textContent = titles[period];
  updateCountdown(period);
  renderLeaderboard(period);
}

function updateCountdown(period) {
  const now = new Date();
  let end;
  if (period === 'weekly') {
    end = new Date(now);
    end.setDate(now.getDate() + (7 - now.getDay()));
    end.setHours(23, 59, 59, 0);
  } else if (period === 'monthly') {
    end = new Date(now.getFullYear(), now.getMonth() + 1, 0, 23, 59, 59);
  } else {
    end = new Date(now.getFullYear(), 11, 31, 23, 59, 59);
  }
  const diff = end - now;
  const d = Math.floor(diff / 86400000);
  const h = Math.floor((diff % 86400000) / 3600000);
  const m = Math.floor((diff % 3600000) / 60000);
  document.getElementById('voteCountdown').textContent = `Resets in: ${d}d ${h}h ${m}m`;
}

// Refresh countdown every minute
setInterval(() => updateCountdown(currentPeriod), 60000);


/* -------------------------------------------------------
   TOAST
------------------------------------------------------- */
let toastTimer;
function showToast(msg, isErr = false) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'show' + (isErr ? ' error' : '');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { el.className = ''; }, 3000);
}


/* -------------------------------------------------------
   LIVE MARKET DATA — DexScreener API
------------------------------------------------------- */
const DEX_PAIR  = 'dryduxz1spns8t5jduubhd37skhrmt9qbklj3vbhuacx';
const TOKEN_CA  = '6jZ11cWQGgUrHhs2sfiCXJGyV6Fa4KtAodU2cRbbpump';
const PAIR_API  = `https://api.dexscreener.com/latest/dex/pairs/solana/${DEX_PAIR}`;
const TOKEN_API = `https://api.dexscreener.com/latest/dex/tokens/${TOKEN_CA}`;

function fmtUsd(n) {
  if (!n && n !== 0) return '—';
  n = parseFloat(n);
  if (n >= 1e9)  return '$' + (n / 1e9).toFixed(2) + 'B';
  if (n >= 1e6)  return '$' + (n / 1e6).toFixed(2) + 'M';
  if (n >= 1e3)  return '$' + (n / 1e3).toFixed(2) + 'K';
  if (n >= 1)    return '$' + n.toFixed(4);
  return '$' + n.toPrecision(4);
}

function fmtPct(n) {
  if (!n && n !== 0) return '—';
  const v = parseFloat(n).toFixed(2);
  return (n >= 0 ? '+' : '') + v + '%';
}

async function tryEndpoint(url, wrapped) {
  const res  = await fetch(url);
  if (!res.ok) throw new Error('HTTP ' + res.status);
  const json = await res.json();
  const data = wrapped ? JSON.parse(json.contents) : json;
  return data.pair || (data.pairs && data.pairs[0]) || null;
}

async function fetchLiveStats() {
  const statusEl = document.getElementById('ls-status');

  const attempts = [
    () => tryEndpoint(PAIR_API,  false),
    () => tryEndpoint(TOKEN_API, false),
    () => tryEndpoint(`https://corsproxy.io/?${encodeURIComponent(PAIR_API)}`,  false),
    () => tryEndpoint(`https://corsproxy.io/?${encodeURIComponent(TOKEN_API)}`, false),
    () => tryEndpoint(`https://api.allorigins.win/raw?url=${encodeURIComponent(PAIR_API)}`,  false),
    () => tryEndpoint(`https://api.allorigins.win/get?url=${encodeURIComponent(PAIR_API)}`,  true),
    () => tryEndpoint(`https://api.allorigins.win/get?url=${encodeURIComponent(TOKEN_API)}`, true),
  ];

  let pair = null;
  for (const attempt of attempts) {
    try {
      pair = await attempt();
      if (pair) break;
    } catch(e) {
      continue;
    }
  }

  if (!pair) {
    statusEl.textContent = '🔴 Live data unavailable — will retry';
    return;
  }

  const price  = pair.priceUsd;
  const change = pair.priceChange?.h24;
  const mcap   = pair.marketCap || pair.fdv;
  const liq    = pair.liquidity?.usd;
  const vol    = pair.volume?.h24;

  const changeEl = document.getElementById('ls-change');
  document.getElementById('ls-price').textContent = price ? fmtUsd(price) : '—';
  changeEl.textContent = change != null ? fmtPct(change) : '—';
  changeEl.className   = 'live-stat-value' + (change >= 0 ? ' positive' : ' negative');
  document.getElementById('ls-mcap').textContent = fmtUsd(mcap);
  document.getElementById('ls-liq').textContent  = fmtUsd(liq);
  document.getElementById('ls-vol').textContent  = fmtUsd(vol);

  statusEl.textContent = `🟢 Updated: ${new Date().toLocaleTimeString()}`;
}

// Fetch on load, then every 60 seconds
window.addEventListener('load', () => { fetchLiveStats(); });
setInterval(fetchLiveStats, 60000);
</script>
