<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>$OSRSFANS – The Old School RuneScape Fan Token</title>
  <link rel="icon" type="image/png" href="data:image/png;base64," />
  <link rel="apple-touch-icon" href="data:image/png;base64," />
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet" />
  <style>
    /* =============================================
       RESET & ROOT
    ============================================= */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d0a06;
      --panel:     #2e2218;
      --panel-lt:  #3d2f1f;
      --border-lt: #8b7355;
      --border-dk: #1a1008;
      --gold:      #c8a020;
      --orange:    #ff981f;
      --text:      #eedcb0;
      --text-dim:  #8b7355;
      --green:     #3dff3d;
      --red:       #ff3d3d;
      --btn-bg:    #4a3520;
      --btn-hover: #6b4f2a;
      --rune-blue: #4466cc;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Press Start 2P', monospace;
      background: var(--bg);
      color: var(--text);
      font-size: 10px;
      line-height: 1.8;
      overflow-x: hidden;
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 10px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border-lt); border: 1px solid var(--gold); }

    /* =============================================
       OSRS PANEL MIXIN
    ============================================= */
    .panel {
      background: var(--panel);
      border: 3px solid var(--border-lt);
      box-shadow:
        inset 2px 2px 0 #c8a040,
        inset -2px -2px 0 var(--border-dk),
        3px 3px 10px rgba(0,0,0,0.7);
    }
    .panel-inner {
      background: var(--panel-lt);
      border: 2px solid var(--border-dk);
      box-shadow: inset 1px 1px 0 var(--border-lt);
    }

    /* =============================================
       STARFIELD CANVAS BACKGROUND
    ============================================= */
    #starfield {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      z-index: 0;
      pointer-events: none;
    }

    /* =============================================
       NAVIGATION
    ============================================= */
    @keyframes bannerPulse { 0%,100%{box-shadow:0 2px 16px rgba(200,160,32,0.3)} 50%{box-shadow:0 2px 28px rgba(200,160,32,0.6)} }

    nav {
      position: fixed;
      top: 36px; left: 0; right: 0;
      z-index: 100;
      background: #0d0a06ee;
      backdrop-filter: blur(4px);
      border-bottom: 3px solid var(--gold);
      box-shadow: 0 2px 20px rgba(200,160,32,0.3);
      padding: 10px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .nav-logo {
      font-size: 14px;
      color: var(--gold);
      text-shadow: 0 0 10px var(--gold), 0 0 20px rgba(200,160,32,0.5);
      letter-spacing: 1px;
    }
    .nav-logo span { color: var(--orange); }

    .nav-links {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
    }
    .nav-links a {
      color: var(--text-dim);
      text-decoration: none;
      font-size: 8px;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--gold); }

    /* =============================================
       BUTTONS
    ============================================= */
    .btn {
      font-family: 'Press Start 2P', monospace;
      font-size: 9px;
      padding: 10px 16px;
      background: var(--btn-bg);
      color: var(--gold);
      border: 2px solid var(--gold);
      box-shadow: inset 1px 1px 0 #c8a040, inset -1px -1px 0 #3a2810, 2px 2px 0 #1a1008;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      transition: all 0.1s;
      image-rendering: pixelated;
    }
    .btn:hover {
      background: var(--btn-hover);
      color: #fff;
      transform: translate(-1px, -1px);
      box-shadow: inset 1px 1px 0 #c8a040, inset -1px -1px 0 #3a2810, 3px 3px 0 #1a1008;
    }
    .btn:active { transform: translate(1px, 1px); box-shadow: none; }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    .btn-lg { font-size: 11px; padding: 14px 24px; }
    .btn-sm { font-size: 8px; padding: 7px 12px; }

    .btn-red   { border-color: var(--red); color: var(--red); }
    .btn-green { border-color: var(--green); color: var(--green); }
    .btn-voted { border-color: var(--text-dim); color: var(--text-dim); cursor: not-allowed; }

    /* Wallet button in nav */
    #connectBtn {
      font-family: 'Press Start 2P', monospace;
      font-size: 8px;
      padding: 8px 14px;
      background: var(--btn-bg);
      color: var(--gold);
      border: 2px solid var(--gold);
      box-shadow: inset 1px 1px 0 #c8a040, inset -1px -1px 0 #3a2810, 2px 2px 0 #1a1008;
      cursor: pointer;
      transition: all 0.1s;
      white-space: nowrap;
    }
    #connectBtn:hover { background: var(--btn-hover); color: #fff; }
    #connectBtn.connected { border-color: var(--green); color: var(--green); }

    /* =============================================
       LAYOUT WRAPPER
    ============================================= */
    main { position: relative; z-index: 1; }
    .section { padding: 80px 20px; max-width: 1100px; margin: 0 auto; }
    .section-title {
      text-align: center;
      font-size: 16px;
      color: var(--gold);
      text-shadow: 0 0 12px rgba(200,160,32,0.6);
      margin-bottom: 8px;
    }
    .section-sub {
      text-align: center;
      font-size: 8px;
      color: var(--text-dim);
      margin-bottom: 50px;
    }
    .divider {
      border: none;
      border-top: 2px solid var(--border-lt);
      box-shadow: 0 1px 0 var(--border-dk);
      margin: 0 auto;
      width: 80%;
    }

    /* =============================================
       HERO
    ============================================= */
    #hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 136px 20px 60px;
      position: relative;
    }

    .hero-coin {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 30%, #fff7a0, #f0c030, #c8860a, #6b4506);
      border: 4px solid #c8a020;
      box-shadow:
        0 0 30px rgba(200,160,32,0.8),
        0 0 60px rgba(200,160,32,0.3),
        inset -6px -6px 12px rgba(0,0,0,0.5),
        inset 4px 4px 8px rgba(255,255,200,0.4);
      margin: 0 auto 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: coinSpin 4s ease-in-out infinite;
      position: relative;
    }
    .hero-coin::after {
      content: '⚔';
      font-size: 40px;
      line-height: 1;
    }

    @keyframes coinSpin {
      0%,100% { transform: rotateY(0deg) scale(1); box-shadow: 0 0 30px rgba(200,160,32,0.8), 0 0 60px rgba(200,160,32,0.3), inset -6px -6px 12px rgba(0,0,0,0.5); }
      50%      { transform: rotateY(20deg) scale(1.05); box-shadow: 0 0 50px rgba(200,160,32,1), 0 0 100px rgba(200,160,32,0.5), inset -6px -6px 12px rgba(0,0,0,0.5); }
    }

    .hero-ticker {
      font-size: clamp(28px, 6vw, 52px);
      color: var(--gold);
      text-shadow: 0 0 20px rgba(200,160,32,0.8), 0 0 40px rgba(200,160,32,0.4);
      letter-spacing: 4px;
      margin-bottom: 16px;
    }

    .hero-tagline {
      font-size: clamp(9px, 2vw, 13px);
      color: var(--text);
      margin-bottom: 30px;
      max-width: 600px;
      line-height: 2.2;
    }

    .hero-badges {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
      margin-bottom: 40px;
    }
    .hero-badge {
      padding: 8px 14px;
      font-size: 8px;
      background: var(--panel);
      border: 2px solid var(--border-lt);
      box-shadow: inset 1px 1px 0 rgba(200,160,64,0.3);
      color: var(--orange);
    }
    .hero-badge span { color: var(--gold); }

    .hero-ctas {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .scroll-hint {
      position: absolute;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 7px;
      color: var(--text-dim);
      animation: bounce 1.5s infinite;
    }
    @keyframes bounce { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(-6px)} }

    /* =============================================
       ABOUT
    ============================================= */
    .about-vision {
      max-width: 820px;
      margin: 0 auto 36px;
      padding: 30px 32px;
      text-align: center;
    }

    .about-vision-title {
      font-size: 1rem;
      color: var(--gold);
      margin-bottom: 10px;
      letter-spacing: .05em;
    }

    .about-vision-sub {
      font-size: .5rem;
      color: var(--orange);
      margin-bottom: 24px;
      letter-spacing: .03em;
    }

    .about-vision-body p {
      font-family: 'Press Start 2P', monospace;
      font-size: .38rem;
      color: var(--text);
      line-height: 2;
      margin-bottom: 16px;
      text-align: left;
    }

    .about-vision-tagline {
      font-size: .42rem !important;
      color: var(--gold) !important;
      text-align: center !important;
      margin-top: 20px !important;
      border-top: 1px solid var(--border-lt);
      padding-top: 16px;
    }

    #about .about-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 20px;
      margin-top: 40px;
    }
    .about-card {
      padding: 24px;
      text-align: center;
    }
    .about-icon {
      font-size: 32px;
      margin-bottom: 16px;
      display: block;
    }
    .about-card h3 {
      font-size: 10px;
      color: var(--gold);
      margin-bottom: 12px;
    }
    .about-card p {
      font-size: 8px;
      color: var(--text);
      line-height: 2;
    }

    /* =============================================
       STREAMER VOTING
    ============================================= */
    #vote { padding-top: 80px; padding-bottom: 80px; }

    .vote-wallet-notice {
      text-align: center;
      margin-bottom: 24px;
      font-size: 8px;
      padding: 14px 20px;
    }
    .vote-wallet-notice.connected { color: var(--green); border-color: var(--green) !important; }
    .vote-wallet-notice.disconnected { color: var(--orange); }

    /* Vote notice banner */
    .vote-notice {
      display: flex;
      align-items: center;
      gap: 16px;
      max-width: 640px;
      margin: 0 auto 24px;
      padding: 16px 22px;
      border: 1px solid var(--orange);
      background: rgba(255,152,31,.08);
      box-shadow: 0 0 14px rgba(255,152,31,.2);
    }

    .vote-notice-icon {
      font-size: 1.6rem;
      flex-shrink: 0;
    }

    .vote-notice-title {
      font-size: .52rem;
      color: var(--orange);
      margin-bottom: 8px;
      letter-spacing: .05em;
    }

    .vote-notice-msg {
      font-size: .38rem;
      color: var(--text);
      line-height: 1.8;
    }

    .vote-notice-date {
      color: var(--gold);
    }

    /* Period tabs */
    .period-tabs {
      display: flex;
      gap: 0;
      margin-bottom: 0;
      border-bottom: 3px solid var(--gold);
    }
    .tab-btn {
      font-family: 'Press Start 2P', monospace;
      font-size: 9px;
      padding: 12px 20px;
      background: var(--panel);
      color: var(--text-dim);
      border: 2px solid var(--border-lt);
      border-bottom: none;
      cursor: pointer;
      transition: all 0.15s;
      flex: 1;
    }
    .tab-btn:hover { color: var(--gold); background: var(--panel-lt); }
    .tab-btn.active {
      background: var(--panel-lt);
      color: var(--gold);
      border-color: var(--gold);
      border-bottom: 3px solid var(--panel-lt);
      margin-bottom: -3px;
      z-index: 1;
      position: relative;
    }

    /* Vote leaderboard */
    .vote-panel {
      padding: 24px;
      margin-top: 0;
    }
    .vote-panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 2px solid var(--border-lt);
    }
    .vote-panel-header h3 { font-size: 10px; color: var(--orange); }
    .vote-countdown { font-size: 7px; color: var(--text-dim); }

    .leaderboard { display: flex; flex-direction: column; gap: 8px; }

    .streamer-row {
      display: grid;
      grid-template-columns: 40px 1fr 120px auto;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      background: var(--panel);
      border: 2px solid var(--border-lt);
      box-shadow: inset 1px 1px 0 rgba(200,160,64,0.15);
      transition: background 0.2s;
    }
    .streamer-row:hover { background: var(--panel-lt); }
    .streamer-row.rank-1 { border-color: #ffd700; box-shadow: 0 0 10px rgba(255,215,0,0.3), inset 1px 1px 0 rgba(255,215,0,0.2); }
    .streamer-row.rank-2 { border-color: #c0c0c0; }
    .streamer-row.rank-3 { border-color: #cd7f32; }

    .rank-badge {
      font-size: 11px;
      text-align: center;
      font-weight: bold;
    }
    .rank-1 .rank-badge { color: #ffd700; text-shadow: 0 0 8px rgba(255,215,0,0.6); }
    .rank-2 .rank-badge { color: #c0c0c0; }
    .rank-3 .rank-badge { color: #cd7f32; }
    .rank-badge.default { color: var(--text-dim); }

    .streamer-info {}
    .streamer-name { font-size: 10px; color: var(--text); margin-bottom: 4px; }
    .streamer-platform { font-size: 7px; color: var(--rune-blue); }

    .vote-bar-wrap {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .vote-bar-bg {
      height: 6px;
      background: var(--border-dk);
      border: 1px solid var(--border-lt);
    }
    .vote-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--gold), var(--orange));
      transition: width 0.6s ease;
    }
    .vote-count { font-size: 7px; color: var(--text-dim); text-align: right; }

    /* Nomination input */
    .nominate-section {
      margin-top: 28px;
      padding-top: 20px;
      border-top: 2px solid var(--border-lt);
    }
    .nominate-section h4 { font-size: 9px; color: var(--gold); margin-bottom: 14px; }
    .nominate-row { display: flex; gap: 10px; flex-wrap: wrap; }
    .osrs-input {
      font-family: 'Press Start 2P', monospace;
      font-size: 9px;
      padding: 10px 14px;
      background: var(--border-dk);
      color: var(--text);
      border: 2px solid var(--border-lt);
      box-shadow: inset 2px 2px 0 rgba(0,0,0,0.5);
      flex: 1;
      min-width: 180px;
      outline: none;
    }
    .osrs-input:focus { border-color: var(--gold); }
    .osrs-input::placeholder { color: var(--text-dim); }

    /* Toast notification */
    #toast {
      position: fixed;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%) translateY(80px);
      z-index: 999;
      padding: 14px 22px;
      font-size: 9px;
      background: var(--panel);
      border: 2px solid var(--gold);
      color: var(--gold);
      box-shadow: 0 0 20px rgba(200,160,32,0.5), inset 1px 1px 0 rgba(200,160,64,0.3);
      transition: transform 0.3s ease;
      max-width: 400px;
      text-align: center;
      pointer-events: none;
    }
    #toast.show { transform: translateX(-50%) translateY(0); }
    #toast.error { border-color: var(--red); color: var(--red); }

    /* =============================================
       TOKENOMICS
    ============================================= */
    /* Live stats */
    .live-stats-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      justify-content: center;
      margin-bottom: 10px;
    }

    .live-stat-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      padding: 16px 20px;
      min-width: 130px;
      text-align: center;
      border: 1px solid var(--border-lt);
      transition: box-shadow .2s;
    }

    .live-stat-card:hover {
      box-shadow: 0 0 14px rgba(200,160,32,.3);
    }

    .live-stat-label {
      font-size: .38rem;
      color: var(--text-dim);
      letter-spacing: .04em;
    }

    .live-stat-value {
      font-size: .7rem;
      color: var(--gold);
      min-height: 1.2em;
    }

    .live-stat-value.positive { color: var(--green); }
    .live-stat-value.negative { color: var(--red); }

    .live-stats-footer {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 32px;
      font-size: .32rem;
      color: var(--text-dim);
    }

    .live-stats-link {
      color: var(--orange);
      text-decoration: none;
      font-size: .32rem;
    }

    .live-stats-link:hover { text-decoration: underline; }

    #tokenomics .token-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 40px;
    }
    .token-card {
      padding: 20px;
      text-align: center;
    }
    .token-label { font-size: 7px; color: var(--text-dim); margin-bottom: 10px; }
    .token-value { font-size: 14px; color: var(--gold); text-shadow: 0 0 10px rgba(200,160,32,0.5); }

    .dist-chart {
      max-width: 500px;
      margin: 0 auto;
    }
    .dist-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
    }
    .dist-label { font-size: 8px; color: var(--text); width: 160px; flex-shrink: 0; }
    .dist-bar-bg {
      flex: 1;
      height: 16px;
      background: var(--border-dk);
      border: 1px solid var(--border-lt);
    }
    .dist-bar-fill {
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 4px;
    }
    .dist-pct { font-size: 7px; color: var(--bg); font-weight: bold; }

    /* =============================================
       ROADMAP
    ============================================= */
    #roadmap .road-list {
      position: relative;
      max-width: 700px;
      margin: 0 auto;
    }
    .road-list::before {
      content: '';
      position: absolute;
      left: 24px;
      top: 0; bottom: 0;
      width: 3px;
      background: linear-gradient(to bottom, var(--gold), var(--border-lt));
    }
    .road-item {
      display: flex;
      gap: 20px;
      margin-bottom: 30px;
      position: relative;
    }
    .road-dot {
      width: 52px;
      height: 52px;
      border-radius: 0;
      background: var(--panel);
      border: 3px solid var(--border-lt);
      box-shadow: inset 1px 1px 0 rgba(200,160,64,0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
      z-index: 1;
    }
    .road-dot.done { border-color: var(--gold); box-shadow: 0 0 10px rgba(200,160,32,0.4), inset 1px 1px 0 rgba(200,160,64,0.3); }
    .road-dot.active { border-color: var(--green); animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{box-shadow:0 0 0 0 rgba(61,255,61,0.4)} 50%{box-shadow:0 0 0 8px rgba(61,255,61,0)} }
    .road-content { padding-top: 8px; }
    .road-phase { font-size: 8px; color: var(--text-dim); margin-bottom: 6px; }
    .road-title { font-size: 11px; color: var(--gold); margin-bottom: 8px; }
    .road-items { font-size: 7px; color: var(--text); line-height: 2.2; }
    .road-items li { list-style: none; padding-left: 12px; position: relative; }
    .road-items li::before { content: '▶'; position: absolute; left: 0; color: var(--gold); font-size: 6px; top: 3px; }
    .road-current { color: var(--green) !important; font-weight: bold; }
    .road-current::before { color: var(--green) !important; }
    .here-arrow {
      display: inline-block;
      margin-left: 10px;
      font-size: 7px;
      color: var(--green);
      text-shadow: 0 0 8px rgba(61,255,61,0.8);
      animation: hereFlash 1.2s ease-in-out infinite;
      white-space: nowrap;
    }
    @keyframes hereFlash { 0%,100%{opacity:1} 50%{opacity:0.3} }

    /* =============================================
       FOOTER
    ============================================= */
    footer {
      border-top: 3px solid var(--gold);
      padding: 40px 20px;
      text-align: center;
    }
    .footer-logo { font-size: 18px; color: var(--gold); margin-bottom: 16px; text-shadow: 0 0 10px rgba(200,160,32,0.5); }
    .footer-tagline { font-size: 7px; color: var(--text-dim); margin-bottom: 28px; }
    .social-links { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-bottom: 30px; }
    .social-link {
      padding: 10px 16px;
      font-size: 8px;
      background: var(--panel);
      border: 2px solid var(--border-lt);
      color: var(--text);
      text-decoration: none;
      transition: all 0.15s;
    }
    .social-link:hover { border-color: var(--gold); color: var(--gold); }
    .footer-small { font-size: 7px; color: var(--text-dim); line-height: 2.2; }
    .footer-small a { color: var(--gold); text-decoration: none; }

    /* =============================================
       VOTE GATE OVERLAY
    ============================================= */
    #votePanel { position: relative; }

    #voteGate {
      position: absolute;
      inset: 0;
      background: rgba(13,10,6,0.88);
      backdrop-filter: blur(3px);
      display: flex;
      align-items: center;
      justify-content: center;
